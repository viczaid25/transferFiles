@{
    ViewData["Title"] = "Nuevo Transfer";
}

<div class="card shadow-sm rounded-lg">
    <div class="card-header custom-header-primary d-flex align-items-center">
        <i class="fa-solid fa-paper-plane me-2"></i>
        <span>Generar link de archivos</span>
    </div>

    <div class="card-body">
        <form id="createTransferForm" asp-action="New" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fa-solid fa-file-arrow-up me-1 text-primary"></i> Selecciona archivos
                </label>
                <input id="filesInput" type="file" name="files" multiple class="form-control" required />
                <div class="form-text text-muted">Puedes seleccionar uno o varios archivos.</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fa-solid fa-message me-1 text-primary"></i> Razón
                </label>
                <textarea id="reasonInput"
                          name="message"
                          class="form-control"
                          rows="3"
                          placeholder="Describe la razón de la transferencia..."
                          required></textarea>
                <div class="form-text text-muted">Este campo es obligatorio.</div>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i> Cancelar
                </a>

                <button id="submitBtn" type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-link me-1"></i> Crear link
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Overlay de carga -->
<div id="loadingOverlay" class="tf-overlay d-none" aria-hidden="true">
    <div class="tf-overlay-card">
        <img src="~/images/uploading.gif" class="tf-gif" alt="Subiendo..." />
        <div class="mt-3 fw-semibold">Generando link…</div>
        <div class="text-muted small">Subiendo archivos a TransferNow. No cierres esta ventana.</div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
          const form = document.getElementById('createTransferForm');
          const overlay = document.getElementById('loadingOverlay');
          const btn = document.getElementById('submitBtn');

          form?.addEventListener('submit', () => {
            // (El browser validará required automáticamente)
            if (btn) {
              btn.disabled = true;
              btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin me-1"></i> Generando…';
            }
            if (overlay) {
              overlay.classList.remove('d-none');
              overlay.setAttribute('aria-hidden', 'false');
            }
          });

          // Si el usuario vuelve con "Back" del navegador, re-habilitar UI
          window.addEventListener('pageshow', () => {
            if (btn) {
              btn.disabled = false;
              btn.innerHTML = '<i class="fa-solid fa-link me-1"></i> Crear link';
            }
            if (overlay) {
              overlay.classList.add('d-none');
              overlay.setAttribute('aria-hidden', 'true');
            }
          });
        })();
    </script>
}
