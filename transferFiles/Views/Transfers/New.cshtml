@{
    ViewData["Title"] = "Nuevo Transfer";
}
<h1 class="display-6">Generar link de archivos</h1>
<form asp-action="New" method="post" enctype="multipart/form-data" class="mt-3">
    <div class="mb-3">
        <label class="form-label">Archivos</label>
        <input type="file" name="files" multiple class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Asunto</label>
        <input type="text" name="subject" class="form-control" />
    </div>
    <div class="mb-3">
        <label class="form-label">Mensaje</label>
        <textarea name="message" class="form-control" rows="3"></textarea>
    </div>
    <button class="btn btn-primary">Crear link</button>
</form>
