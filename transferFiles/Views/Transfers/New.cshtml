@{
    ViewData["Title"] = "Nuevo Transfer";
}

<div class="card shadow-sm rounded-lg">
    <div class="card-header custom-header-primary d-flex align-items-center">
        <i class="fa-solid fa-paper-plane me-2"></i>
        <span>Generar link de archivos</span>
    </div>
    <div class="card-body">
        <form asp-action="New" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fa-solid fa-file-arrow-up me-1 text-primary"></i> Selecciona archivos
                </label>
                <input type="file" name="files" multiple class="form-control" required />
                <div class="form-text text-muted">Puedes seleccionar uno o varios archivos</div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fa-solid fa-heading me-1 text-primary"></i> Titulo
                </label>
                <input type="text" name="subject" class="form-control" placeholder="Ej. Reporte mensual" />
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    <i class="fa-solid fa-message me-1 text-primary"></i> Descripcion
                </label>
				<textarea name="message" class="form-control" rows="3" placeholder="Agrega una descripcion opcional..."></textarea>
            </div>

            <div class="d-flex justify-content-end gap-2">
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fa-solid fa-arrow-left me-1"></i> Cancelar
                </a>
                <button type="submit" class="btn btn-primary">
                    <i class="fa-solid fa-link me-1"></i> Crear link
                </button>
            </div>
        </form>
    </div>
</div>
