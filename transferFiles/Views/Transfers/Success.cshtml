@{
    ViewData["Title"] = "Transfer creado";
    var link = (string)ViewBag.TransferLink;
    var pwd = (string)ViewBag.Password;
    var validityDays = (int?)ViewBag.ValidityDays ?? 7;
}

<div class="card shadow-sm rounded-lg mt-2">
    <div class="card-header custom-header-primary d-flex align-items-center">
        <i class="fa-solid fa-circle-check me-2"></i>
        <span>¡Listo! Tu link fue generado</span>
    </div>

    <div class="card-body">
        <p class="mb-3">
            El link está protegido con contraseña y es válido por <strong>@validityDays día@(validityDays == 1 ? "" : "s")</strong>.
        </p>

        <!-- Link -->
        <label class="form-label fw-semibold"><i class="fa-solid fa-link me-1 text-primary"></i> Link</label>
        <div class="input-group mb-3">
            <input id="generatedLink" class="form-control" value="@link" readonly />
            <button id="copyLinkBtn" type="button" class="btn btn-outline-secondary">
                <i class="fa-regular fa-copy me-1"></i> Copiar
            </button>
            <a href="@link" target="_blank" rel="noopener" class="btn btn-primary">
                <i class="fa-solid fa-up-right-from-square me-1"></i> Abrir
            </a>
        </div>

        <!-- Password -->
        <label class="form-label fw-semibold"><i class="fa-solid fa-lock me-1 text-primary"></i> Contraseña</label>
        <div class="input-group mb-2">
            <input id="generatedPassword" class="form-control" value="@pwd" readonly />
            <button id="copyPwdBtn" type="button" class="btn btn-outline-secondary">
                <i class="fa-regular fa-copy me-1"></i> Copiar
            </button>
        </div>
        <div class="form-text">El link y la contraseña se copiaron automáticamente al portapapeles.</div>

        <!-- Copiar ambos -->
        <div class="d-flex flex-wrap gap-2 mt-4">
            <button id="copyBothBtn" type="button" class="btn btn-outline-primary">
                <i class="fa-regular fa-copy me-1"></i> Copiar link + contraseña
            </button>
            <a asp-controller="Transfers" asp-action="New" class="btn btn-outline-secondary">
                <i class="fa-solid fa-plus me-1"></i> Crear otro
            </a>
            <a asp-controller="Links" asp-action="Mine" class="btn btn-outline-primary">
                <i class="fa-solid fa-link me-1"></i> Ver mis links
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
          const linkInput = document.getElementById('generatedLink');
          const pwdInput  = document.getElementById('generatedPassword');
          const copyLinkBtn = document.getElementById('copyLinkBtn');
          const copyPwdBtn  = document.getElementById('copyPwdBtn');
          const copyBothBtn = document.getElementById('copyBothBtn');

          async function copyText(text) {
            try {
              await navigator.clipboard.writeText(text);
              return true;
            } catch {
              const tmp = document.createElement('input');
              tmp.value = text;
              document.body.appendChild(tmp);
              tmp.select();
              document.execCommand('copy');
              document.body.removeChild(tmp);
              return true;
            }
          }

          function flash(btn, okHtml) {
            const old = btn.innerHTML;
            btn.innerHTML = okHtml;
            setTimeout(() => btn.innerHTML = old, 1200);
          }

          // Auto-copiar ambos al cargar
          (async () => {
            if (linkInput?.value) await copyText(linkInput.value);
            if (pwdInput?.value)  await copyText(pwdInput.value);
          })();

          copyLinkBtn?.addEventListener('click', async () => {
            if (await copyText(linkInput.value)) flash(copyLinkBtn, '<i class="fa-solid fa-check me-1"></i> Copiado');
          });

          copyPwdBtn?.addEventListener('click', async () => {
            if (await copyText(pwdInput.value)) flash(copyPwdBtn, '<i class="fa-solid fa-check me-1"></i> Copiado');
          });

          copyBothBtn?.addEventListener('click', async () => {
            const combined = `Link: ${linkInput.value}\nPassword: ${pwdInput.value}`;
            if (await copyText(combined)) flash(copyBothBtn, '<i class="fa-solid fa-check me-1"></i> Copiado');
          });
        })();
    </script>
}
