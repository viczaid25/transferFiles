@model IEnumerable<transferFiles.Models.ViewModels.TransferLinkRowVm>
@using System.Linq
@using System

@{
    ViewData["Title"] = "Mis links generados";
    int validityDays = ViewBag.ValidityDays ?? 7;
}

<div class="card shadow-sm rounded-lg">
    <div class="card-header custom-header-primary d-flex align-items-center">
        <i class="fa-solid fa-link me-2"></i>
        <span>@ViewData["Title"]</span>
    </div>

    <div class="card-body">
        <div class="d-flex justify-content-end mb-2">
            <span class="badge bg-light fw-semibold" style="color:#000;">
                Vigencia: @validityDays día@(validityDays == 1 ? "" : "s")
            </span>
        </div>

        <!-- resto del contenido -->
    </div>


    <div class="card-body">

        <p class="text-muted mb-3">
            Usuario: <strong>@(ViewBag.CurrentUser ?? "")</strong>
        </p>

        <!-- Filtro local (cliente) -->
        <div class="input-group mb-3">
            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input id="filterInput" type="text" class="form-control" placeholder="Filtrar por archivo o URL..." aria-label="Filtrar" />
            <button id="clearFilter" class="btn btn-outline-secondary" type="button">Limpiar</button>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="card shadow-sm rounded-lg">
                <div class="card-body">
                    <div class="text-muted">Aún no has generado links.</div>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table id="linksTable" class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Creado (UTC)</th>
                            <th>Expira (UTC)</th>
                            <th>Archivo</th>
                            <th>Link</th>
                            <th>Estatus</th>
                            <th>🔐 Contraseña</th>
                            <th style="width:1%"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model)
                        {
                            var badgeClass = row.IsExpired ? "bg-danger" : "bg-success";
                            <tr>
                                <td>@TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(row.CreatedAtUtc, DateTimeKind.Utc), TimeZoneInfo.Local).ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@TimeZoneInfo.ConvertTimeFromUtc(DateTime.SpecifyKind(row.ExpiresAtUtc, DateTimeKind.Utc), TimeZoneInfo.Local).ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-truncate" style="max-width:260px">@row.FileName</td>

                                <td class="text-truncate" style="max-width:420px">
                                    <a href="@row.Link" target="_blank" rel="noopener">@row.Link</a>
                                </td>

                                <td>
                                    <span class="badge @badgeClass">@(row.IsExpired ? "Expired" : "Active")</span>
                                    @if (!row.IsExpired)
                                    {
                                        <small class="text-muted ms-2">
                                            (~@Math.Ceiling(row.Remaining.TotalHours) h)
                                        </small>
                                    }
                                </td>

                                <!-- Columna contraseña -->
                                <td class="text-nowrap">
                                    @if (!string.IsNullOrEmpty(row.Password))
                                    {
                                        <div class="input-group input-group-sm" style="max-width:230px">
                                            <input type="password"
                                                   class="form-control pwd-field"
                                                   value="@row.Password"
                                                   readonly />
                                            <button type="button"
                                                    class="btn btn-outline-secondary toggle-pwd-btn"
                                                    title="Mostrar/Ocultar">
                                                <i class="fa-regular fa-eye"></i>
                                            </button>
                                            <button type="button"
                                                    class="btn btn-outline-secondary copy-pwd-btn"
                                                    title="Copiar contraseña">
                                                <i class="fa-regular fa-copy"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>

                                <td class="text-nowrap">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary copy-link-btn"
                                            data-link="@row.Link"
                                            title="Copiar link">
                                        <i class="fa-regular fa-copy"></i>
                                    </button>
                                    <a class="btn btn-sm btn-primary" href="@row.Link" target="_blank" rel="noopener" title="Abrir">
                                        <i class="fa-solid fa-up-right-from-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
          // Copiar LINK (ya lo tenías)
          document.addEventListener('click', async (e) => {
            const linkBtn = e.target.closest('.copy-link-btn');
            if (!linkBtn) return;
            const url = linkBtn.getAttribute('data-link') || '';
            if (!url) return;

            async function copy(text) {
              try { await navigator.clipboard.writeText(text); }
              catch {
                const tmp = document.createElement('input');
                tmp.value = text; document.body.appendChild(tmp);
                tmp.select(); document.execCommand('copy');
                document.body.removeChild(tmp);
              }
            }

            const old = linkBtn.innerHTML;
            await copy(url);
            linkBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
            setTimeout(() => linkBtn.innerHTML = old, 1100);
          });

          // Mostrar/ocultar contraseña por fila
          document.addEventListener('click', (e) => {
            const toggleBtn = e.target.closest('.toggle-pwd-btn');
            if (!toggleBtn) return;
            const group = toggleBtn.closest('.input-group');
            const input = group?.querySelector('.pwd-field');
            const icon = toggleBtn.querySelector('i');
            if (!input) return;

            if (input.type === 'password') {
              input.type = 'text';
              if (icon) { icon.classList.remove('fa-eye'); icon.classList.add('fa-eye-slash'); }
            } else {
              input.type = 'password';
              if (icon) { icon.classList.remove('fa-eye-slash'); icon.classList.add('fa-eye'); }
            }
          });

          // Copiar contraseña por fila
          document.addEventListener('click', async (e) => {
            const copyPwdBtn = e.target.closest('.copy-pwd-btn');
            if (!copyPwdBtn) return;
            const group = copyPwdBtn.closest('.input-group');
            const input = group?.querySelector('.pwd-field');
            if (!input) return;

            const text = input.value || '';
            async function copy(text) {
              try { await navigator.clipboard.writeText(text); }
              catch {
                const tmp = document.createElement('input');
                tmp.value = text; document.body.appendChild(tmp);
                tmp.select(); document.execCommand('copy');
                document.body.removeChild(tmp);
              }
            }

            const old = copyPwdBtn.innerHTML;
            await copy(text);
            copyPwdBtn.innerHTML = '<i class="fa-solid fa-check"></i>';
            setTimeout(() => copyPwdBtn.innerHTML = old, 1100);
          });

        })();
    </script>
}

