@model IEnumerable<transferFiles.Models.ViewModels.TransferLinkRowVm>
@{
    ViewData["Title"] = "Mis links generados";
    int validityDays = ViewBag.ValidityDays ?? 7;
}

<div class="card shadow-sm rounded-lg">
    <div class="card-header custom-header-primary d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center">
            <i class="fa-solid fa-link me-2"></i>
            <span>@ViewData["Title"]</span>
        </div>
        <span class="badge bg-light text-dark">Vigencia: @validityDays día@(validityDays == 1 ? "" : "s")</span>
    </div>

    <div class="card-body">
        <p class="text-muted mb-3">
            Usuario: <strong>@(ViewBag.CurrentUser ?? "")</strong>
        </p>

        <!-- Filtro local (cliente) -->
        <div class="input-group mb-3">
            <span class="input-group-text"><i class="fa-solid fa-magnifying-glass"></i></span>
            <input id="filterInput" type="text" class="form-control" placeholder="Filtrar por archivo o URL..." aria-label="Filtrar" />
            <button id="clearFilter" class="btn btn-outline-secondary" type="button">Limpiar</button>
        </div>

        @if (!Model.Any())
        {
            <div class="text-muted">Aún no has generado links.</div>
        }
        else
        {
            <div class="table-responsive">
                <table id="linksTable" class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Creado (UTC)</th>
                            <th>Expira (UTC)</th>
                            <th>Archivo</th>
                            <th>Link</th>
                            <th>Estatus</th>
                            <th style="width:1%"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var row in Model)
                        {
                            var badgeClass = row.IsExpired ? "bg-danger" : "bg-success";
                            <tr>
                                <td data-col="created">@row.CreatedAtUtc:yyyy-MM-dd HH:mm:ss</td>
                                <td data-col="expires">@row.ExpiresAtUtc:yyyy-MM-dd HH:mm:ss</td>
                                <td data-col="file" class="text-truncate" style="max-width:260px">@row.FileName</td>
                                <td data-col="link" class="text-truncate" style="max-width:420px">
                                    <a href="@row.Link" target="_blank" rel="noopener">@row.Link</a>
                                </td>
                                <td data-col="status">
                                    <span class="badge @badgeClass">@(row.IsExpired ? "Expired" : "Active")</span>
                                    @if (!row.IsExpired)
                                    {
                                        <small class="text-muted ms-2">
                                            (~@Math.Ceiling(row.Remaining.TotalHours) h)
                                        </small>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    <button type="button"
                                            class="btn btn-sm btn-outline-secondary copy-link-btn"
                                            data-link="@row.Link"
                                            title="Copiar link">
                                        <i class="fa-regular fa-copy"></i>
                                    </button>
                                    <a class="btn btn-sm btn-primary" href="@row.Link" target="_blank" rel="noopener" title="Abrir">
                                        <i class="fa-solid fa-up-right-from-square"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        (function () {
          // Copiar con feedback
          document.addEventListener('click', async (e) => {
            const btn = e.target.closest('.copy-link-btn');
            if (!btn) return;
            const url = btn.getAttribute('data-link') || '';
            if (!url) return;

            async function copy(text) {
              try {
                await navigator.clipboard.writeText(text);
              } catch {
                const tmp = document.createElement('input');
                tmp.value = text;
                document.body.appendChild(tmp);
                tmp.select();
                document.execCommand('copy');
                document.body.removeChild(tmp);
              }
            }

            const oldHtml = btn.innerHTML;
            await copy(url);
            btn.innerHTML = '<i class="fa-solid fa-check"></i>';
            setTimeout(() => btn.innerHTML = oldHtml, 1200);
          });

          // Filtro local simple (archivo / URL)
          const filterInput = document.getElementById('filterInput');
          const clearBtn = document.getElementById('clearFilter');
          const tbody = document.querySelector('#linksTable tbody');

          function applyFilter() {
            const q = (filterInput.value || '').toLowerCase().trim();
            if (!tbody) return;
            for (const tr of tbody.rows) {
              const file = (tr.querySelector('[data-col="file"]')?.textContent || '').toLowerCase();
              const link = (tr.querySelector('[data-col="link"]')?.textContent || '').toLowerCase();
              tr.style.display = (file.includes(q) || link.includes(q)) ? '' : 'none';
            }
          }

          filterInput?.addEventListener('input', applyFilter);
          clearBtn?.addEventListener('click', () => { filterInput.value = ''; applyFilter(); });
        })();
    </script>
}
