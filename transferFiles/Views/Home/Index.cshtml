@model transferFiles.Models.ViewModels.HomeIndexVm
@{
    ViewData["Title"] = "Inicio";
}

<div class="container-fluid">
    <!-- Hero -->
    <div class="card shadow-sm mb-4 rounded-lg">
        <div class="card-body py-4">
            <div class="d-lg-flex align-items-center justify-content-between">
                <div class="mb-3 mb-lg-0">
                    <h1 class="h3 mb-1 page-title">Bienvenido</h1>
                    <p class="text-muted mb-0">
                        Hola <strong>@Model.CurrentUser</strong>. Genera y administra tus links de transferencia.
                        Los links tienen vigencia de <strong>@Model.ValidityDays días</strong>.
                    </p>
                </div>
                <div class="d-grid d-sm-flex gap-2">
                    <a asp-controller="Transfers" asp-action="New" class="btn btn-primary">
                        <i class="fa-solid fa-paper-plane me-1"></i> Crear link
                    </a>
                    <a asp-controller="Links" asp-action="Mine" class="btn btn-outline-primary">
                        <i class="fa-solid fa-link me-1"></i> Mis links
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="fw-bold text-muted">Total de mis links</div>
                    <div class="display-6">@Model.TotalMyLinks</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="fw-bold text-muted">Activos</div>
                    <div class="display-6 text-success">@Model.ActiveMyLinks</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <div class="fw-bold text-muted">Expirados</div>
                    <div class="display-6 text-danger">@Model.ExpiredMyLinks</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Últimos links -->
    <div class="card shadow-sm rounded-lg">
        <div class="card-header custom-header-primary">
            <div class="d-flex align-items-center">
                <i class="fa-solid fa-clock-rotate-left me-2"></i>
                <span>Últimos links generados</span>
            </div>
        </div>
        <div class="card-body">
            @if (Model.Recent.Count == 0)
            {
                <div class="text-muted">Aún no has generado links. ¡Crea el primero!</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Creado (UTC)</th>
                                <th>Archivo</th>
                                <th>Expira (UTC)</th>
                                <th>Estado</th>
                                <th>Link</th>
                                <th style="width:1%"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.Recent)
                            {
                                var badge = row.IsExpired ? "bg-danger" : "bg-success";
                                <tr>
                                    <td>@row.CreatedAtUtc</td>
                                    <td class="text-truncate" style="max-width:260px">@row.FileName</td>
                                    <td>@row.ExpiresAtUtc</td>
                                    <td>
                                        <span class="badge @badge">@(row.IsExpired ? "Expired" : "Active")</span>
                                    </td>
                                    <td class="text-truncate" style="max-width:360px;">
                                        <a href="@row.Link" target="_blank" rel="noopener">@row.Link</a>
                                    </td>
                                    <td>
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary copy-link-btn"
                                                data-link="@row.Link" title="Copiar">
                                            Copiar
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="text-end mt-3">
                    <a asp-controller="Links" asp-action="Mine" class="btn btn-outline-primary btn-sm">
                        Ver todos
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('click', async (e) => {
          const btn = e.target.closest('.copy-link-btn');
          if (!btn) return;
          const url = btn.getAttribute('data-link');
          try {
            await navigator.clipboard.writeText(url);
            btn.textContent = 'Copiado';
            setTimeout(() => btn.textContent = 'Copiar', 1200);
          } catch {
            const tmp = document.createElement('input');
            tmp.value = url;
            document.body.appendChild(tmp);
            tmp.select();
            document.execCommand('copy');
            document.body.removeChild(tmp);
            btn.textContent = 'Copiado';
            setTimeout(() => btn.textContent = 'Copiar', 1200);
          }
        });
    </script>
}
